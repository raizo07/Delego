{
  "name": "delego",
  "version": "0.0.1",
  "private": true,
  "description": "AI commerce platform with Stellar/Soroban wallet, escrow, and agent delegation",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r --filter './apps/frontend' --filter './apps/backend/*' --filter './agents' dev",
    "dev:web": "pnpm --filter @delego/web dev",
    "dev:gateway": "pnpm --filter @delego/gateway dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter @delego/tests-unit test",
    "test:integration": "pnpm --filter @delego/tests-integration test",
    "test:contracts": "pnpm --filter './contracts/*' test",
    "test:e2e": "pnpm --filter @delego/tests-e2e test",
    "db:migrate": "node scripts/setup/migrate.js",
    "db:seed": "node scripts/setup/seed.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "pnpm -r exec rm -rf dist .next node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "pg": "^8.21.0"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^15.1.0"
  }
}
